{
  "name": "student-grade-management-api",
  "version": "2.0.0",
  "description": "A modern, production-ready Node.js RESTful API for managing students, evaluations, and grades with secure JWT authentication and OpenAPI Swagger documentation.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env index.js",
    "dev": "node --watch --env-file=.env index.js",
    "lint": "eslint .",
    "seed": "node database/seed.js",
    "test": "node --env-file=.env.test --test"
  },
  "keywords": [
    "nodejs",
    "express",
    "sqlite",
    "jwt",
    "rest-api",
    "openapi",
    "swagger"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "csv-parser": "^3.0.0",
    "express": "^5.0.1",
    "express-validator": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "sqlite3": "^5.1.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0"
  }
}
